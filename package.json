{
  "name": "@43081j/npm-high-impact-deprecations",
  "version": "0.1.0",
  "private": true,
  "description": "A collection of package sreps.",
  "homepage": "https://github.com/43081j/npm-high-impact-deprecation#readme",
  "bugs": {
    "url": "https://github.com/43081j/npm-high-impact-deprecation/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/43081j/npm-high-impact-deprecation.git"
  },
  "license": "MIT",
  "author": "James Garbutt (https://github.com/43081j)",
  "type": "module",
  "main": "lib/main.js",
  "files": [
    "lib",
    "!lib/**/*.test.js",
    "!lib/**/*.test.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "generate": "node src/generate.ts",
    "find-deprecated": "node src/find-deprecated.ts",
    "report": "node src/report.ts",
    "lint:js": "oxlint src",
    "lint:format": "oxfmt --check src",
    "lint": "npm run lint:js && npm run lint:format",
    "format": "oxfmt --write src",
    "test": "node --test"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "npm-high-impact": "^1.13.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2"
  }
}
